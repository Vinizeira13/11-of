# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=<service role secret — SERVER ONLY, nunca expose>

# Cart cookie HMAC — gere com `openssl rand -hex 32`
# Em produção precisa de >= 32 chars, ou o build falha.
CART_SECRET=

# pague.dev — sandbox (pd_test_*) em dev, live (pd_live_*) em prod
PAGUE_API_KEY=
PAGUE_WEBHOOK_SECRET=
# PAGUE_API_BASE=https://api.pague.dev    # opcional

# Site — usado em metadata, JSON-LD e share URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
